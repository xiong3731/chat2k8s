# WeChat Configuration
WECHAT_BOT_ID=your_bot_id
WECHAT_BOT_SECRET=your_bot_secret
WECHAT_WSS_URL=wss://openws.work.weixin.qq.com

# MCP Configuration
# Format: JSON array of strings
# MCP_K8S_COMMAND=["docker", "run", "-i", "--rm", "-v", "/path/to/kubeconfig:/etc/kubernetes/admin.conf:ro", "ghcr.io/containers/kubernetes-mcp-server:latest", "--kubeconfig", "/etc/kubernetes/admin.conf", "--read-only"]
# MCP_FS_COMMAND=["docker", "run", "-i", "--rm", "-v", "/path/to/docs:/projects/guide_doc:ro", "mcp/filesystem", "/projects"]

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.modelverse.cn/v1
OPENAI_MODEL=zai-org/glm-5
MAX_HISTORY_ROUNDS=10

# RAG Configuration
RAG_ENABLED=False
RAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
RAG_EMBEDDING_API_BASE=http://117.50.226.140:8000/v1
RAG_EMBEDDING_API_KEY=none

RAG_LLM_MODEL=openai/gpt-5.2
RAG_LLM_API_KEY=your_rag_llm_api_key
RAG_LLM_API_BASE=https://api.modelverse.cn/v1

RAG_MILVUS_HOST=127.0.0.1
RAG_MILVUS_PORT=19530
RAG_MILVUS_COLLECTION_NAME=sre_small_to_big_hybrid_vstore

RAG_RERANK_MODEL=Qwen3-VL-Reranker-8B
RAG_RERANK_API_URL=http://106.75.44.131:8000/rerank
RAG_RERANK_TIMEOUT=10
